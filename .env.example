# ================================================================
# 스마트 헬스케어 백엔드 서버 환경변수 설정
# 이 파일을 복사하여 .env 파일을 만들고 값을 채워주세요.
#   cp .env.example .env
# ================================================================

# ---------------------------------------------------------------
# 서버 설정
# ---------------------------------------------------------------

# Express 서버 포트 (기본값: 3000)
PORT=3000

# ---------------------------------------------------------------
# SQLite DB 설정
# ---------------------------------------------------------------

# DB 파일 경로 (기본값: ./data/healthcare.db)
DB_PATH=./data/healthcare.db

# ---------------------------------------------------------------
# MQTT 브로커 설정
# ---------------------------------------------------------------

# Mosquitto 브로커 주소
# 로컬 실행 시: mqtt://localhost:1883
# Raspberry Pi를 브로커로 사용 시: mqtt://{Pi의 IP 주소}:1883
MQTT_BROKER_URL=mqtt://localhost:1883

# 구독할 토픽 (기본값: healthcare/+/event)
MQTT_TOPIC=healthcare/+/event

# MQTT 브로커 인증 정보 (인증 설정 시에만 입력, 없으면 비워두세요)
MQTT_USERNAME=
MQTT_PASSWORD=

# ---------------------------------------------------------------
# 알림 설정
# ---------------------------------------------------------------

# 알림 채널 선택
#   console  → 실제 SMS 발송 없이 콘솔에만 출력 (개발/테스트용)
#   aws-sns  → AWS SNS를 통해 실제 SMS 발송 (운영용)
ALERT_CHANNEL=console

# 동일 사용자에 대한 알림 재발송 최소 간격 (분 단위, 기본값: 10)
ALERT_COOLDOWN_MINUTES=10

# SMS 발송 실패 시 최대 재시도 횟수 (기본값: 3)
ALERT_MAX_RETRIES=3

# ---------------------------------------------------------------
# AWS 설정 (ALERT_CHANNEL=aws-sns 인 경우에만 필요)
# ---------------------------------------------------------------

# AWS 리전
AWS_REGION=ap-northeast-1

# AWS 자격증명
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
